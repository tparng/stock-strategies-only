# FinMind API (免費註冊: https://finmindtrade.com/)
FINMIND_TOKEN=your_finmind_token_here

# Telegram Bot (找 @BotFather 建立)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Sheet
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account JSON (整串壓成一行)
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# AI 策略生成後端（Web UI 用，可選）
# 有 GEMINI_API_KEY 時預設走 Gemini；本機有 GPU 可改用 Ollama
# AI_PROVIDER=ollama          # gemini | ollama（不設則自動判斷）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b   # 推薦：中文強、JSON 準、14B 約佔 9GB VRAM
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
